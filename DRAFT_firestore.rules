rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation helper for bookings
    function isValidBooking(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.matches('^[^@]+@[^@]+\\\\.[^@]+$') &&
             data.phone is string && data.phone.size() <= 20 &&
             data.address is string && data.address.size() > 0 && data.address.size() <= 500 &&
             data.propertyType in ['residential', 'commercial'] &&
             data.chargerType is string && data.chargerType.size() <= 200 &&
             data.preferredDate is timestamp &&
             data.status in ['pending', 'confirmed', 'completed', 'cancelled'] &&
             data.createdAt is timestamp;
    }

    match /bookings/{bookingId} {
      // Allow creation by anyone (lead generation)
      allow create: if isValidId(bookingId) && 
                      isValidBooking(incoming()) &&
                      incoming().status == 'pending' &&
                      incoming().createdAt == request.time;
      
      // Allow read/update/delete only if admin or eventually owner if we had auth users
      // For now, let's say admins can read all, or users can read their own if authenticated
      allow read: if isSignedIn() && (request.auth.token.email_verified == true);
      
      allow update: if isSignedIn() && 
                      request.auth.token.email_verified == true &&
                      isValidBooking(incoming()) &&
                      incoming().createdAt == existing().createdAt;

      allow delete: if isSignedIn() && request.auth.token.email_verified == true;
    }
  }
}
