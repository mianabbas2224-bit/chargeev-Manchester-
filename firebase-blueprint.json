{
  "entities": {
    "booking": {
      "title": "Booking",
      "description": "An EV charging installation booking request.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Customer name" },
        "email": { "type": "string", "format": "email", "description": "Customer email" },
        "phone": { "type": "string", "description": "Customer phone number" },
        "address": { "type": "string", "description": "Installation address" },
        "propertyType": { "type": "string", "enum": ["home", "business"], "description": "Type of property" },
        "chargerType": { "type": "string", "description": "Type of charger requested" },
        "carModel": { "type": "string", "description": "Client's car make and model" },
        "installationLocation": { "type": "string", "description": "Desired charger location" },
        "spareWays": { "type": "string", "description": "Spare ways in consumer unit" },
        "cableRun": { "type": "string", "description": "Estimated cable run distance" },
        "preferredDate": { "type": "string", "format": "date-time", "description": "Requested installation date" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"], "description": "Booking status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the booking was created" }
      },
      "required": ["name", "email", "address", "propertyType", "preferredDate", "status", "createdAt"]
    }
  },
  "firestore": {
    "bookings": {
      "schema": "booking",
      "description": "Collection of installation bookings"
    }
  }
}
